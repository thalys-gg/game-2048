{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Type-check target; Vite handles actual transpilation for the browser
    "target": "ES2020",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "DOM.AsyncIterable"],
    "moduleDetection": "force",
    "useDefineForClassFields": true,

    "module": "ESNext",
    "moduleResolution": "bundler",

    "paths": {
      "∆/*": ["./src/engine/*"],
      "@/*": ["./src/app/*"],
      "#/*": ["./scripts/*"]
    },

    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true,

    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noUncheckedSideEffectImports": false,

    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": false,
    "skipLibCheck": true,

    // Browser-safe globals only — Bun/Node types live in tsconfig.node.json
    "types": ["pixi.js", "vite-plugin-glsl/ext"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".cache", "dist", "public"]
}
