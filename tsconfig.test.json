{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["./tsconfig.core.json"],
  "compilerOptions": {
    "tsBuildInfoFile": ".cache/tsconfig.test.tsbuildinfo",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "DOM.AsyncIterable"],
    "types": [],
    "outDir": "./dist-test",
    "erasableSyntaxOnly": false
  },
  "include": ["src/test", "src/**/*.test.ts", "src/**/*.spec.ts"],
  "exclude": ["node_modules", ".cache", ".vscode", "dist*", "public"]
}
