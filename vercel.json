{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.3",
  "framework": "vite",
  "outputDirectory": "dist/",
  "installCommand": "bun install --ignore-scripts",
  "buildCommand": "bun run prepare && bun run build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
