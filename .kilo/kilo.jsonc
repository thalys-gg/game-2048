{
  "$schema": "https://app.kilo.ai/config.json",
  "experimental": {
    "batch_tool": true
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd"
      ],
      "enabled": true
    }
  }
}
