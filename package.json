{
  "name": "@thalys/game-2048",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "2048 Game",
  "author": "Thalys Moisyn <thalys@ppd.gg>",
  "license": "UNLICENSED",
  "homepage": "https://github.com/thalys/game-2048#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalys/game-2048.git"
  },
  "bugs": {
    "url": "https://github.com/thalys/game-2048/issues"
  },
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun run lint && tsc && bunx --bun vite build",
    "clean": "rm -rf bun.lock node_modules/ .cache/ .assetpack/ public/assets/ src/gen/*",
    "clean:assets": "rm -rf .assetpack/ public/assets/",
    "lint": "bunx --bun eslint",
    "fix": "bunx --bun eslint --fix",
    "check": "bunx --bun tsc --noEmit -p ./tsconfig.app.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepare": "vp config"
  },
  "dependencies": {
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.3.2",
    "@thalys/anime-pixi": "^0.0.1",
    "motion": "^12.40.0",
    "pixi.js": "^8.19.0",
    "typed-signals": "^3.0.0"
  },
  "devDependencies": {
    "@assetpack/core": "1.7.0",
    "@pixi/devtools": "^2.0.1",
    "@thalys/logger": "^1.0.3",
    "@types/node": "^24",
    "bun-types": "^1.3.14",
    "eslint-plugin-command": "^3.5.2",
    "pixi-stats": "^5.1.7",
    "typescript": "^5",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-glsl": "^1",
    "vite-plugin-terminal": "^1",
    "vite-plus": "latest"
  },
  "trustedDependencies": [
    "@ffmpeg-installer/darwin-arm64",
    "core-js",
    "cpu-features",
    "esbuild",
    "sharp",
    "simple-git-hooks"
  ],
  "packageManager": "bun@1.3.14",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
