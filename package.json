{
  "name": "@thalys/game-2048",
  "version": "0.0.33",
  "private": true,
  "description": "2048 Game",
  "homepage": "https://github.com/thalys/game-2048#readme",
  "bugs": {
    "url": "https://github.com/thalys/game-2048/issues"
  },
  "license": "MIT",
  "author": "Thalys Moisyn <thalys@ppd.gg>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalys/game-2048.git"
  },
  "type": "module",
  "imports": {
    "#/*": "./scripts/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf bun.lock node_modules/ .cache/ .assetpack/ public/assets/ src/gen/*",
    "clean:assets": "rm -rf .assetpack/ public/assets/",
    "lint": "oxlint -c oxlint.config.ts",
    "fix": "oxlint -c oxlint.config.ts --fix; oxfmt ./ --no-error-on-unmatched-pattern --write",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.3.2",
    "@thalys/anime-pixi": "^0.0.1",
    "motion": "^12.40.0",
    "pixi.js": "^8.19.0",
    "typed-signals": "^3.0.0"
  },
  "devDependencies": {
    "@assetpack/core": "1.7.0",
    "@pixi/devtools": "^2.0.1",
    "@thalys/logger": "^1.0.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260613.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.69.0",
    "typescript": "^6",
    "vite": "^8.0.16",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-glsl": "^1.6.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@ffmpeg-installer/darwin-arm64",
    "core-js",
    "cpu-features",
    "esbuild",
    "sharp"
  ]
}
