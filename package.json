{
  "name": "@thalys/game-2048",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "2048 Game",
  "author": "Thalys Moisyn <thalys@ppd.gg>",
  "license": "UNLICENSED",
  "homepage": "https://github.com/thalys/game-2048#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalys/game-2048.git"
  },
  "bugs": {
    "url": "https://github.com/thalys/game-2048/issues"
  },
  "scripts": {
    "start": "bunx --bun run dev",
    "dev": "bunx --bun vite",
    "build": "bunx --bun run lint && tsc && bunx --bun vite build",
    "clean": "rm -rf bun.lock node_modules/ .cache/ .assetpack/ public/assets/ src/gen/*",
    "clean:assets": "rm -rf .assetpack/ public/assets/",
    "lint": "bunx --bun eslint",
    "fix": "bunx --bun eslint --fix",
    "check": "bunx --bun tsc --noEmit -p ./tsconfig.app.json"
  },
  "dependencies": {
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.3.2",
    "@thalys/anime-pixi": "^0.0.1",
    "gsap": "^3.14.1",
    "motion": "12.23.25",
    "pixi.js": "^8.8.1",
    "typed-signals": "^3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.3.0",
    "@assetpack/core": "1.4.0",
    "@eslint-react/eslint-plugin": "^1",
    "@pixi/devtools": "^2.0.1",
    "@thalys/eslint-config": "^0.2.6",
    "@thalys/logger": "link:@thalys/logger",
    "@types/bun": "latest",
    "@types/node": "24.0.13",
    "eslint": "^9",
    "eslint-plugin-command": "^3",
    "eslint-plugin-format": "^1",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0",
    "pixi-stats": "^5.0.3",
    "typescript": "^5",
    "vite": "7.0.4",
    "vite-plugin-devtools-json": "0.2.1",
    "vite-plugin-glsl": "^1",
    "vite-plugin-terminal": "^1"
  },
  "trustedDependencies": [
    "@ffmpeg-installer/darwin-arm64",
    "core-js",
    "cpu-features",
    "esbuild",
    "sharp",
    "simple-git-hooks"
  ]
}
