{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tooling that runs under Bun/Node: vite config, lint config, scripts
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext"],
    "types": ["@assetpack/core", "vite-plugin-glsl/ext", "vite", "bun", "node"],
    // Scripts are executed directly via type stripping, so keep syntax erasable
    "erasableSyntaxOnly": true
  },
  "include": ["vite.config.ts", "oxlint.config.ts", "scripts/**/*"]
}
